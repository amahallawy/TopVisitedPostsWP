<?xml version="1.0"?>
<ruleset name="TopVisitedPosts">
    <description>Coding standards for the Top Visited Posts plugin.</description>

    <!-- Scan the plugin root by default. -->
    <file>.</file>

    <!-- Skip vendored / generated paths. -->
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
    <exclude-pattern>.github/</exclude-pattern>

    <!-- Only scan PHP files. -->
    <arg name="extensions" value="php"/>

    <!-- Show progress and use colors. -->
    <arg name="colors"/>
    <arg value="ps"/>
    <arg name="parallel" value="4"/>

    <!-- WordPress Coding Standards. -->
    <rule ref="WordPress"/>

    <!-- Tell the i18n sniff which text domain we use. -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="top-visited-posts"/>
            </property>
        </properties>
    </rule>

    <!-- PHP version compatibility. -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="7.4-"/>
    <config name="minimum_supported_wp_version" value="5.8"/>
</ruleset>
